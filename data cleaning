import pandas as pd
import numpy as np

# ── Load the raw JHU wide-format CSV ─────────────────────────────────────────
df_raw = pd.read_csv('time_series_covid19_confirmed_global.csv')

# Filter to UK rows only — JHU uses 'United Kingdom' as Country/Region
# There are 15 sub-region rows (England, Scotland, Wales, N.Ireland, territories)
uk = df_raw[df_raw['Country/Region'] == 'United Kingdom'].copy()

# The date columns start at position 4 (after Province, Country, Lat, Long)
date_cols = df_raw.columns[4:]

# Sum all sub-regions into a single national cumulative series
# axis=0 sums down rows for each date column
uk_cumulative = uk[date_cols].sum(axis=0)  # shape: (1143,) — one value per day

# Convert cumulative counts to daily new cases via first-difference
# diff() subtracts each value from the previous one
uk_daily = uk_cumulative.diff().fillna(0)

# Clip negative values to 0 — these are data corrections in the JHU feed
# (3 negative values found in the raw data)
uk_daily = uk_daily.clip(lower=0)

# Resample to weekly: sum Monday-to-Sunday blocks
# First convert index to DatetimeIndex so we can use resample()
uk_daily.index = pd.to_datetime(uk_daily.index, format='%m/%d/%y')
uk_weekly = uk_daily.resample('W-MON').sum()   # 163 weeks total
from scipy.signal import savgol_filter

# Raw counts as a numpy array
obs_raw = uk_weekly.values.astype(float)  # shape: (163,)

# Savitzky-Golay: window=11 weeks, polynomial degree=3
# window must be odd; degree must be less than window
# This smooths the series while preserving peak structure
obs_smooth = savgol_filter(obs_raw, window_length=11, polyorder=3)

# Clip any negative smoothed values (can occur at the start of the series)
obs_smooth = np.clip(obs_smooth, 0, None)

# 'obs' is our target for all model fitting going forward
obs = obs_smooth   # shape: (163,)
T   = len(obs)     # T = 163 weeks
UK_POPULATION = 67_000_000   # 2021 ONS estimate

# Per-100K transformation: divide by population, multiply by 100,000
obs_per100k     = obs_raw    / UK_POPULATION * 1e5
obs_sm_per100k  = obs_smooth / UK_POPULATION * 1e5

# Week index: integer 0, 1, 2, ... 162
# Used as the time axis for all models
week_index = np.arange(T, dtype=float)   # shape: (163,)
t_obs      = week_index.copy()           # alias used in ODE solver
 Build the clean output dataframe
df_clean = pd.DataFrame({
    'week_start':           uk_weekly.index,
    'uk_cases_raw':         obs_raw,
    'uk_cases_smooth':      obs_smooth,
    'uk_cases_raw_per100k': obs_per100k,
    'uk_cases_smooth_per100k': obs_sm_per100k,
    'week_index':           week_index.astype(int)
})

df_clean.to_csv('uk_weekly_cases_clean.csv', index=False)
