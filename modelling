# ── SIRS ODE right-hand side ──────────────────────────────────────────────────
def sirs_const(y, t, beta, gamma, omega):
    """
    y     : [S, I, R] compartment fractions (sum ≈ 1)
    t     : time (weeks) — not used explicitly since beta is constant
    beta  : transmission rate (/week)
    gamma : recovery rate (/week)  → mean infectious period = 1/gamma
    omega : immunity loss rate (/week) → mean immunity duration = 1/omega
    """
    S, I, R = y
    N = S + I + R   # should equal 1 but kept for numerical safety
    dS = -beta * S * I / N  +  omega * R
    dI = +beta * S * I / N  -  gamma * I
    dR = +gamma * I          -  omega * R
    return [dS, dI, dR]

# ── Loss function ─────────────────────────────────────────────────────────────
def ode_loss(log_params):
    """
    Parameters are log-transformed so optimiser works in unconstrained space:
    log_params = [log(beta), log(gamma), log(omega), log(k)]
    Taking exp() ensures all parameters remain strictly positive.
    """
    beta, gamma, omega, k = np.exp(log_params)

    # Solve ODE from fixed initial conditions
    # S0=0.9999: nearly all susceptible at start of pandemic
    # I0=1e-6:   tiny seed infection
    # R0=1e-4:   negligible prior immunity
    try:
        sol = odeint(sirs_const, [0.9999, 1e-6, 1e-4],
                     t_obs,
                     args=(beta, gamma, omega),
                     rtol=1e-6, atol=1e-8)
    except Exception:
        return 1e6   # penalise solver failures

    # I(t) from ODE is a population fraction; multiply by k to map to obs scale
    # k absorbs: (i) population size, (ii) ascertainment rate, (iii) other scaling
    I_pred = sol[:, 1] * k   # normalised prediction

    # Mean squared error in normalised space
    return np.mean((I_pred - obs_n) ** 2)

