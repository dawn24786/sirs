# ── Network architecture ──────────────────────────────────────────────────────
# Input:  t (scalar, normalised to [0,1])
# Hidden: 1 → 16 → 32 → 16
# Output: 3 nodes → softmax → (S, I, R) — softmax ensures S+I+R=1 always

ARCH = [1, 16, 32, 16, 3]   # layer sizes

def count_params(arch):
    """Count total parameters: for each layer, W has (in×out) entries, b has (out) entries."""
    return sum((arch[i] + 1) * arch[i+1] for i in range(len(arch)-1))

N_PARAMS = count_params(ARCH)   # 1,155 parameters

def forward_pass(t_pts, params, arch=ARCH):
    """
    t_pts : shape (N,) — normalised time values in [0,1]
    params: flat 1D array of all network weights and biases
    Returns: shape (N, 3) — softmax output representing (S%, I%, R%)
    """
    idx = 0
    h   = t_pts.reshape(-1, 1)   # (N, 1) — column vector input

    for i in range(len(arch) - 1):
        n_in, n_out = arch[i], arch[i+1]

        # Unpack weight matrix W (n_out × n_in) and bias b (n_out,)
        W   = params[idx : idx + n_in*n_out].reshape(n_out, n_in)
        b   = params[idx + n_in*n_out : idx + n_in*n_out + n_out]
        idx += n_in*n_out + n_out

        # Linear transform: h = h @ W.T + b
        h = h @ W.T + b

        # Apply activation: tanh for hidden layers, softmax for output
        if i < len(arch) - 2:
            h = np.tanh(h)
        else:
            # Numerically stable softmax: subtract max before exp
            e = np.exp(h - h.max(axis=1, keepdims=True))
            h = e / e.sum(axis=1, keepdims=True)

    return h   # shape (N, 3)

# ── Central finite differences for dSIR/dt ────────────────────────────────────
def d_dt(t_pts, params, eps=0.05):
    """
    Approximate time derivatives using central differences:
    f'(t) ≈ [f(t+eps) − f(t−eps)] / (2*eps)
    eps=0.05 in normalised time ≈ 8 weeks — smooths high-frequency noise
    """
    return (forward_pass(t_pts + eps, params) -
            forward_pass(t_pts - eps, params)) / (2 * eps)

# ── Normalised time axis ───────────────────────────────────────────────────────
t_n = t_obs / t_obs.max()   # map [0, 162] → [0, 1]

# ── PINN loss function ─────────────────────────────────────────────────────────
def pinn_loss(x, lam_phys=1.0):
    """
    x: flat vector [network_params (1155), log_beta, log_gamma, log_omega, log_k]
    lam_phys: weight on physics term (higher = stronger physics constraint)
    """
    net_params = x[:N_PARAMS]
    beta, gamma, omega = np.exp(x[N_PARAMS:N_PARAMS+3])
    k = np.exp(x[-1])

    # ── Data loss ─────────────────────────────────────────────────────────────
    SIR    = forward_pass(t_n, net_params)        # (T, 3)
    I_pred = SIR[:, 1] * k                        # normalised I × scale factor
    L_data = np.mean((I_pred - obs_n) ** 2)       # MSE in normalised space

    # ── Physics loss ──────────────────────────────────────────────────────────
    dSIR = d_dt(t_n, net_params)                  # (T, 3) — derivatives
    S, I, R = SIR[:, 0], SIR[:, 1], SIR[:, 2]
    N = np.clip(S + I + R, 1e-8, None)            # prevent division by zero

    # Compute the ODE right-hand side at each time point
    ode_S = -beta * S * I / N  +  omega * R
    ode_I = +beta * S * I / N  -  gamma * I
    ode_R = +gamma * I          -  omega * R

    # Physics residual: how much does the network's derivative disagree with ODE?
    rS = dSIR[:, 0] - ode_S
    rI = dSIR[:, 1] - ode_I
    rR = dSIR[:, 2] - ode_R
    L_phys = np.mean(rS**2 + rI**2 + rR**2)

    return L_data + lam_phys * L_phys

