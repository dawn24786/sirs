def sirs_seg(y, t, beta_val):
    """SIRS ODE for a single segment with constant beta_val."""
    S, I, R = y;  N = S + I + R
    return [
        -beta_val*S*I/N + omega_fix*R,
         beta_val*S*I/N - gamma_fix*I,
         gamma_fix*I    - omega_fix*R
    ]

def solve_with_continuity(log_betas, bps, T,
                          S0=0.9999, I0=1e-6):
    """
    Solve SIRS piecewise, enforcing state continuity at each breakpoint.

    log_betas : array of K log(β) values, one per segment
    bps       : array of K-1 breakpoint positions (week indices, possibly float)
    Returns   : arrays S(t), I(t), R(t) of length T
    """
    # Sort and clip breakpoints to valid integer week indices
    bps_i = np.sort(np.clip(np.array(bps), 1, T-2).astype(int))
    # Build segment boundaries: [0, bp1, bp2, ..., T]
    segs  = np.concatenate([[0], bps_i, [T]])

    all_S, all_I, all_R = [], [], []
    y_cur = [S0, I0, 1 - S0 - I0]   # initial condition

    for si in range(len(segs) - 1):
        t0, t1 = int(segs[si]), int(segs[si+1])
        if t1 <= t0:
            continue

        # Local time axis for this segment (starts at 0)
        t_seg    = t_obs[t0:t1] - t_obs[t0]
        beta_val = float(np.exp(log_betas[si]))

        # Solve ODE on this segment from current state y_cur
        sol = odeint(sirs_seg, y_cur, t_seg,
                     args=(beta_val,), rtol=1e-6, atol=1e-8, mxstep=500)

        all_S.extend(sol[:, 0])
        all_I.extend(sol[:, 1])
        all_R.extend(sol[:, 2])

        # ← ISSUE 7 KEY LINE: hand final state to next segment
        y_cur = list(sol[-1])

    return np.array(all_S), np.array(all_I), np.array(all_R)

def pw_loss(p, K):
    """
    p = [log_beta_0, ..., log_beta_{K-1},   <- K transmission rates
         bp_1, ..., bp_{K-1},               <- K-1 breakpoints (float)
         log_k]                              <- observation scale
    """
    log_betas = p[:K]
    bps       = p[K : K + K - 1]
    k         = np.exp(p[-1])

    S, I, R = solve_with_continuity(log_betas, bps, T)
    if len(I) < T:
        return 1e6   # solver failure penalty

    I_pred = I * k
    return np.mean((I_pred - obs_n) ** 2)

