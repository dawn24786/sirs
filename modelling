    p0 = np.array([np.log(0.4), np.log(0.33), np.log(1e-5), np.log(0.01)])
    p0 += rng.normal(0, 0.5, 4)   # ±0.5 in log space = roughly ×1.65 perturbation

    # Stage 1: Nelder-Mead (gradient-free, good for rough landscapes)
    r1 = minimize(ode_loss, p0, method='Nelder-Mead',
                  options=dict(maxiter=3000, xatol=1e-9, fatol=1e-11))

    # Stage 2: Powell polish (coordinate-descent, tightens the solution)
    r2 = minimize(ode_loss, r1.x, method='Powell',
                  options=dict(maxiter=2000, xtol=1e-10, ftol=1e-12))

    if r2.fun < best_loss:
        best_loss   = r2.fun
        best_result = r2

